# Copy to .env and fill in your paths, then `source .env` before running dev tools or launching the mod.
#
# NONE of these are needed to PLAY the mod — its game features read original data straight from your own
# Dark Cloud ISO at runtime (no extraction). These only enable DEV TOOLING and IN-GAME DIAGNOSTICS, and if
# a variable is unset the tool/diagnostic that needs it simply does not run.

# Extracted Dark Cloud (DC1) disc dir — required by the DC1 reverse-engineering tools in tools/.
export DC1_DATA_DIR="/absolute/path/to/dc1_extracted"

# Extracted Dark Cloud 2 (DC2) disc dir — required by the DC2 tools in game_data/re_tools/.
export DC2_DATA_DIR="/absolute/path/to/dc2_extracted"

# Dark Cloud 2 ISO — required by game_data/re_tools/dc2/dc2_archive.py.
export DC2_ISO="/absolute/path/to/dark_cloud_2.iso"

# Where the mod writes in-game diagnostic dumps (collision CSVs). UNSET ⇒ dumps are skipped entirely.
# Point it at your reference folder, e.g. <repo>/game_data/brownboo.
export DC_DUMP_DIR="/absolute/path/to/repo/game_data/brownboo"
